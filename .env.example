# ContextOS — environment variable reference
# Copy this file to .env and adjust values for your local setup.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# API service (apps/api)
# ---------------------------------------------------------------------------

# Address the Go API server binds to.
# Format: host:port — leave host empty to bind on all interfaces.
API_ADDR=:8080

# ---------------------------------------------------------------------------
# AI Worker service (apps/ai-worker)
# ---------------------------------------------------------------------------

# Port the Python health/worker server listens on.
WORKER_PORT=8081

# ---------------------------------------------------------------------------
# Frontend service (apps/frontend)
# ---------------------------------------------------------------------------

# Vite dev-server proxy targets.
# In Docker Compose these point to service names; locally use localhost.
API_URL=http://localhost:8080
WORKER_URL=http://localhost:8081
