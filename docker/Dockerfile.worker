# Minimal Python 3.12 image — health.py uses only stdlib so no extra packages needed
FROM python:3.12-slim

RUN groupadd --system appgroup && \
    useradd --system --gid appgroup --no-create-home appuser

WORKDIR /app

COPY apps/ai-worker/health.py .

USER appuser

EXPOSE 8081

CMD ["python", "health.py"]
