        "/filesystem/upload": {
            "post": {
                "description": "Accepts multipart/form-data with one or more file parts and optional relative paths, stages them under storage/raw/uploads/\u003cupload-id\u003e/, and ingests through the filesystem connector. Metadata keys filesystem_upload_id, filesystem_upload_root, filesystem_upload_file_count, and filesystem_upload_original_name are added to each result event.",
