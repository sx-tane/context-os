                "parameters": [
                    {
                        "type": "file",
                        "description": "One or more files to upload",
                        "name": "files",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Relative paths for browser folder uploads (one per file, matching file order)",
                        "name": "paths",
                        "in": "formData"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.Ingest"
