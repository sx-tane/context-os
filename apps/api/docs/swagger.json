    "definitions": {
        "events.Event": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string",
                    "example": "Issue body: Please update the connector README with setup steps."
                },
                "id": {
                    "type": "string",
                    "example": "evt_a1b2c3d4e5f6"
                },
                "metadata": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "occurred_at": {
                    "type": "string",
                    "example": "2026-05-29T10:00:00Z"
                },
                "schema_version": {
                    "type": "string",
                    "example": "v1"
                },
                "source": {
                    "type": "string",
                    "example": "github"
                },
                "source_id": {
                    "type": "string",
                    "example": "https://github.com/sx-tane/context-os/issues/1"
                },
                "subject": {
                    "type": "string",
                    "example": "Fix: update connector README"
                },
                "trace_id": {
                    "type": "string",
                    "example": "trace_a1b2c3d4e5f6"
                },
                "type": {
                    "allOf": [
                        {
                            "$ref": "#/definitions/events.Type"
                        }
                    ],
                    "example": "document.ingested"
                }
            }
        },
        "events.Type": {
            "type": "string",
            "enum": [
                "document.ingested",
                "document.normalized",
                "entity.extracted",
                "identity.resolved",
                "relationship.created",
                "mismatch.detected",
                "codex.analysis.completed"
            ],
            "x-enum-varnames": [
                "DocumentIngested",
                "DocumentNormalized",
                "EntityExtracted",
                "IdentityResolved",
                "RelationshipCreated",
                "MismatchDetected",
                "CodexAnalysisComplete"
            ]
        },
        "request.FilesystemIngest": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string",
                    "example": "Optional raw content instead of reading from URI"
                },
                "cursor": {
                    "type": "string",
                    "example": "eyJsYXN0X2lkIjoiMTIzIn0="
                },
                "exclude": {
                    "type": "string",
                    "example": "node_modules,*.log"
                },
                "include": {
                    "type": "string",
                    "example": "*.go,*.md"
                },
                "metadata": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "uri": {
